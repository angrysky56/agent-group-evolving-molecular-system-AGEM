# AGEM Configuration
# Copy to .env and adjust values

# ─── LLM Providers ───
LLM_PROVIDER=minimax               # "ollama" | "openrouter" | "anthropic" | "minimax"
EMBEDDING_PROVIDER=ollama         # optional: override embedding provider

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest

# OpenRouter (cloud)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-preview
OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-001

# MiniMax (cloud)
MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=Mini-Max-M2.7
# MINIMAX_EMBEDDING_MODEL=embo-01

# ─── Server ───
PORT=8000
HOST=0.0.0.0

# ─── Knowledge Base ───
# KNOWLEDGE_BASE_PATH=./knowledge_base   # defaults to project root

# ─── AGEM Engine ───
#
# MAX_AGENT_POOL_SIZE — how many concurrent "agent slots" the orchestrator keeps
#   open for internal sub-processes (e.g. Van der Waals gap-bridging agents).
#   Raise this if you want the system to explore more semantic gaps in parallel.
#   Lower it on memory-constrained machines. Default: 20
# MAX_AGENT_POOL_SIZE=20
#
# MAX_ITERATIONS — the total number of top-level orchestration cycles the engine
#   will run before stopping. Each cycle ingests one user message, runs TNA graph
#   updates, SOC metrics, sheaf cohomology, and regime classification.
#   Default: 50  (Set this to 200 for long-running sessions)
# MAX_ITERATIONS=50
#
# VDW_AGENT_MAX_ITERATIONS — the maximum number of reasoning "turns" each
#   Van der Waals sub-agent is allowed before it self-terminates. VdW agents are
#   lightweight exploratory agents spawned when a sheaf H¹ obstruction (semantic
#   gap) is detected. Hitting the cap triggers the "Hit max turns" log message.
#   Raise this to let agents do more work on hard gaps; lower it to keep costs down.
#   Default: 50
# VDW_AGENT_MAX_ITERATIONS=50
