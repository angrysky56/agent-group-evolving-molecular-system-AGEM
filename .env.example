# AGEM Configuration
# Copy to .env and adjust values

# ─── LLM Providers ───
LLM_PROVIDER=minimax               # "ollama" | "openrouter" | "anthropic" | "minimax"
EMBEDDING_PROVIDER=ollama         # optional: override embedding provider

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest
OLLAMA_EMBEDDING_MODEL=embeddinggemma:latest

# OpenRouter (cloud)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-2.5-flash-preview
OPENROUTER_EMBEDDING_MODEL=google/gemini-embedding-001

# MiniMax (cloud)
MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=Mini-Max-M2.7
# MINIMAX_EMBEDDING_MODEL=embo-01

# ─── Server ───
PORT=8000
HOST=0.0.0.0

# ─── Knowledge Base ───
# KNOWLEDGE_BASE_PATH=./knowledge_base   # defaults to project root

# ─── AGEM Engine ───
# MAX_AGENT_POOL_SIZE=20
# MAX_ITERATIONS=50
